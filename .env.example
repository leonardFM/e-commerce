# Gunakan dedicated PostgreSQL user (bukan superuser) untuk aplikasi.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solutech?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solutech_test?schema=public"
# ⚠️ Minimal 32 karakter untuk development. Ganti dengan nilai unik untuk production.
JWT_SECRET="dev-secret-min-32-chars-localhost-only!!!"
REDIS_URL="redis://localhost:6379"
LOG_LEVEL="info"
LOG_DESTINATION="stdout"
LOG_FILE_PATH="logs/app.jsonl"
SLOW_QUERY_THRESHOLD_MS="100"
SLOW_CACHE_THRESHOLD_MS="50"
# SEED_PASSWORD="your-custom-password"  # Opsional, untuk kustomisasi password seed
